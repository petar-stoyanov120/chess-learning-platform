# Database (required)
DATABASE_URL="postgresql://chess:chess_secret@localhost:5432/chess_learn"

# JWT secrets (required — generate strong random strings)
JWT_ACCESS_SECRET="change-this-to-a-random-32-character-string"
JWT_REFRESH_SECRET="change-this-to-a-different-random-32-character-string"

# JWT token expiry (optional, defaults shown)
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
UPLOAD_DIR="./public/uploads"

# SMTP — email notifications (optional, disabled if not set)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="user@example.com"
# SMTP_PASS="password"
# SMTP_FROM="noreply@chesslearn.local"
