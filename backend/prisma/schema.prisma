generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  users     User[]

  @@map("roles")
}

model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  username            String    @unique
  passwordHash        String    @map("password_hash")
  displayName         String?   @map("display_name")
  avatarUrl           String?   @map("avatar_url")
  roleId              Int       @map("role_id")
  clubId              Int?      @map("club_id")
  isActive            Boolean   @default(true) @map("is_active")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  tokenVersion        Int       @default(0) @map("token_version")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  role                     Role                        @relation(fields: [roleId], references: [id])
  club                     Club?                       @relation(fields: [clubId], references: [id], onDelete: SetNull)
  refreshTokens            RefreshToken[]
  lessons                  Lesson[]                    @relation("LessonAuthor")
  approvedLessons          Lesson[]                    @relation("LessonApprover")
  blogPosts                BlogPost[]                  @relation("BlogAuthor")
  approvedPosts            BlogPost[]                  @relation("BlogApprover")
  lessonProgress           LessonProgress[]
  bookmarks                Bookmark[]
  playlists                Playlist[]
  ownedClassrooms          Classroom[]                 @relation("ClassroomOwner")
  classroomMembers         ClassroomMember[]
  puzzleSubmissions        ClassroomPuzzleSubmission[]
  lessonRatings            LessonRating[]
  comments                 Comment[]
  locationCoaches          LocationCoach[]
  locationNoticesAuthored  LocationNotice[]            @relation("NoticeAuthor")
  locationNoticesReviewed  LocationNotice[]            @relation("NoticeReviewer")

  @@index([clubId])
  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  lessons Lesson[]

  @@map("categories")
}

model DifficultyLevel {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  sortOrder Int      @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  lessons Lesson[]

  @@map("difficulty_levels")
}

model PostStatus {
  id   Int    @id @default(autoincrement())
  name String @unique

  lessons   Lesson[]
  blogPosts BlogPost[]

  @@map("post_statuses")
}

model Lesson {
  id                Int      @id @default(autoincrement())
  title             String
  slug              String   @unique
  content           String
  excerpt           String?
  authorId          Int      @map("author_id")
  categoryId        Int      @map("category_id")
  difficultyLevelId Int      @map("difficulty_level_id")
  statusId          Int      @map("status_id")
  coverImageUrl     String?  @map("cover_image_url")
  sortOrder         Int      @default(0) @map("sort_order")
  viewCount         Int      @default(0) @map("view_count")
  approvedBy        Int?     @map("approved_by")
  approvedAt        DateTime? @map("approved_at")
  rejectionReason   String?  @map("rejection_reason")
  readingTime       Int?     @map("reading_time")
  metaDescription   String?  @map("meta_description")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  author               User                      @relation("LessonAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  approver             User?                     @relation("LessonApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  category             Category                  @relation(fields: [categoryId], references: [id])
  level                DifficultyLevel           @relation(fields: [difficultyLevelId], references: [id])
  status               PostStatus                @relation(fields: [statusId], references: [id])
  diagrams             LessonDiagram[]
  lessonTags           LessonTag[]
  lessonProgress       LessonProgress[]
  variations           Variation[]
  bookmarks            Bookmark[]
  playlistLessons      PlaylistLesson[]
  classroomLessons     ClassroomPlaylistLesson[]
  lessonRatings        LessonRating[]
  comments             Comment[]

  @@index([statusId])
  @@index([authorId])
  @@index([categoryId, difficultyLevelId, statusId])
  @@map("lessons")
}

model LessonProgress {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  lessonId    Int      @map("lesson_id")
  completedAt DateTime @default(now()) @map("completed_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model LessonDiagram {
  id        Int      @id @default(autoincrement())
  lessonId  Int      @map("lesson_id")
  fen       String
  caption   String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_diagrams")
}

model BlogPost {
  id              Int      @id @default(autoincrement())
  title           String
  slug            String   @unique
  content         String
  excerpt         String?
  authorId        Int      @map("author_id")
  statusId        Int      @map("status_id")
  coverImageUrl   String?  @map("cover_image_url")
  approvedBy      Int?     @map("approved_by")
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?  @map("rejection_reason")
  readingTime     Int?     @map("reading_time")
  metaDescription String?  @map("meta_description")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  author       User          @relation("BlogAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  approver     User?         @relation("BlogApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  status       PostStatus    @relation(fields: [statusId], references: [id])
  blogPostTags BlogPostTag[]
  variations   Variation[]

  @@index([statusId])
  @@index([authorId])
  @@map("blog_posts")
}

model Variation {
  id         Int       @id @default(autoincrement())
  name       String
  notation   String
  sortOrder  Int       @default(0) @map("sort_order")
  lessonId   Int?      @map("lesson_id")
  blogPostId Int?      @map("blog_post_id")
  createdAt  DateTime  @default(now()) @map("created_at")

  lesson   Lesson?   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  blogPost BlogPost? @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([blogPostId])
  @@map("variations")
}

model Tag {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  slug         String        @unique
  lessonTags   LessonTag[]
  blogPostTags BlogPostTag[]

  @@map("tags")
}

model LessonTag {
  lessonId Int @map("lesson_id")
  tagId    Int @map("tag_id")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([lessonId, tagId])
  @@map("lesson_tags")
}

model BlogPostTag {
  blogPostId Int @map("blog_post_id")
  tagId      Int @map("tag_id")

  blogPost BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogPostId, tagId])
  @@map("blog_post_tags")
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  lessonId  Int      @map("lesson_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("bookmarks")
}

model Playlist {
  id          Int              @id @default(autoincrement())
  userId      Int              @map("user_id")
  name        String
  description String?
  isPublic    Boolean          @default(false) @map("is_public")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessons PlaylistLesson[]

  @@map("playlists")
}

model PlaylistLesson {
  id         Int      @id @default(autoincrement())
  playlistId Int      @map("playlist_id")
  lessonId   Int      @map("lesson_id")
  addedAt    DateTime @default(now()) @map("added_at")
  sortOrder  Int      @default(0) @map("sort_order")

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  lesson   Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([playlistId, lessonId])
  @@map("playlist_lessons")
}

// ─── Clubs, Locations & Location Notices ────────────────────────────────────

model Club {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  logoUrl     String?  @map("logo_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  members   User[]
  locations Location[]

  @@map("clubs")
}

model Location {
  id              Int      @id @default(autoincrement())
  clubId          Int      @map("club_id")
  name            String
  description     String?
  address         String?
  scheduleInfo    String?  @map("schedule_info") @db.Text
  addressVisible  Boolean  @default(true)  @map("address_visible")
  scheduleVisible Boolean  @default(true)  @map("schedule_visible")
  isActive        Boolean  @default(true)  @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  club       Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  coaches    LocationCoach[]
  classrooms Classroom[]
  notices    LocationNotice[]

  @@index([clubId])
  @@index([isActive])
  @@map("locations")
}

model LocationCoach {
  id         Int      @id @default(autoincrement())
  locationId Int      @map("location_id")
  userId     Int      @map("user_id")
  role       String   @default("coach")
  addedAt    DateTime @default(now()) @map("added_at")

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([locationId, userId])
  @@index([userId])
  @@map("location_coaches")
}

model LocationNotice {
  id         Int       @id @default(autoincrement())
  locationId Int       @map("location_id")
  authorId   Int       @map("author_id")
  title      String
  content    String    @db.Text
  status     String    @default("published")
  expiresAt  DateTime? @map("expires_at")
  reviewedBy Int?      @map("reviewed_by")
  reviewedAt DateTime? @map("reviewed_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt      @map("updated_at")

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  author   User     @relation("NoticeAuthor",   fields: [authorId],   references: [id], onDelete: Cascade)
  reviewer User?    @relation("NoticeReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([locationId])
  @@index([status])
  @@map("location_notices")
}

// ─── Classroom / Club System ────────────────────────────────────────────────

model Classroom {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  inviteCode  String   @unique @map("invite_code")
  ownerId     Int      @map("owner_id")
  locationId  Int?     @map("location_id")
  ageMin      Int?     @map("age_min")
  ageMax      Int?     @map("age_max")
  isActive    Boolean  @default(true) @map("is_active")
  tier        String   @default("free")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner            User                @relation("ClassroomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  location         Location?           @relation(fields: [locationId], references: [id], onDelete: SetNull)
  members          ClassroomMember[]
  playlists        ClassroomPlaylist[]
  puzzles          ClassroomPuzzle[]
  classroomLessons ClassroomLesson[]

  @@index([ownerId])
  @@index([locationId])
  @@map("classrooms")
}

model ClassroomMember {
  id          Int      @id @default(autoincrement())
  classroomId Int      @map("classroom_id")
  userId      Int      @map("user_id")
  joinedAt    DateTime @default(now()) @map("joined_at")

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classroomId, userId])
  @@map("classroom_members")
}

model ClassroomPlaylist {
  id           Int      @id @default(autoincrement())
  classroomId  Int      @map("classroom_id")
  name         String
  description  String?
  teacherIntro String?  @map("teacher_intro")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  classroom Classroom               @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  lessons   ClassroomPlaylistLesson[]

  @@index([classroomId])
  @@map("classroom_playlists")
}

model ClassroomPlaylistLesson {
  id                  Int     @id @default(autoincrement())
  classroomPlaylistId Int     @map("classroom_playlist_id")
  lessonId            Int     @map("lesson_id")
  sortOrder           Int     @default(0) @map("sort_order")
  teacherNote         String? @map("teacher_note")

  playlist ClassroomPlaylist @relation(fields: [classroomPlaylistId], references: [id], onDelete: Cascade)
  lesson   Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([classroomPlaylistId, lessonId])
  @@map("classroom_playlist_lessons")
}

// ─── Classroom Puzzles ──────────────────────────────────────────────────────

model ClassroomPuzzle {
  id          Int       @id @default(autoincrement())
  classroomId Int       @map("classroom_id")
  lessonId    Int?      @map("lesson_id")
  title       String
  description String?   @db.Text
  fen         String
  sideToMove  String    @map("side_to_move")
  solution    String?   @db.Text
  maxMoves    Int?      @map("max_moves")
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  classroom   Classroom                   @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  lesson      ClassroomLesson?            @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  submissions ClassroomPuzzleSubmission[]

  @@index([classroomId])
  @@index([lessonId])
  @@map("classroom_puzzles")
}

// ─── Classroom Custom Lessons ───────────────────────────────────────────────

model ClassroomLesson {
  id          Int      @id @default(autoincrement())
  classroomId Int      @map("classroom_id")
  title       String
  content     String   @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  classroom Classroom        @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  puzzles   ClassroomPuzzle[]

  @@index([classroomId])
  @@map("classroom_lessons")
}

model ClassroomPuzzleSubmission {
  id            Int       @id @default(autoincrement())
  puzzleId      Int       @map("puzzle_id")
  userId        Int       @map("user_id")
  notation      String    @db.Text
  notes         String?   @db.Text
  submittedAt   DateTime  @default(now()) @map("submitted_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  reviewedAt    DateTime? @map("reviewed_at")
  isCorrect     Boolean?  @map("is_correct")
  coachFeedback String?   @db.Text @map("coach_feedback")

  puzzle ClassroomPuzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([puzzleId, userId])
  @@index([puzzleId])
  @@map("classroom_puzzle_submissions")
}

// ─── Comments & Ratings ─────────────────────────────────────────────────────

model LessonRating {
  id       Int    @id @default(autoincrement())
  userId   Int    @map("user_id")
  lessonId Int    @map("lesson_id")
  value    Int

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_ratings")
}

model Comment {
  id        Int      @id @default(autoincrement())
  lessonId  Int      @map("lesson_id")
  userId    Int      @map("user_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("comments")
}
